#!/usr/bin/env bash
#MISE description="Build/compile the review v2026.3.0 response PDF."
#MISE dir="{{ config_root }}/tex/"
#MISE depends=["review-v2026.3.0:update-refs"]
#MISE sources=["review-v2026.3.0.tex", "review-v2026.3.0.bib"]
#MISE outputs=["review-v2026.3.0.pdf"]
CURRENT_LATEST=$(git describe --tags --abbrev=0 2>/dev/null)
[[ "$CURRENT_LATEST" != "v2026.3.0" ]] && { echo "review-v2026.3.0: skipping, newer revision exists"; exit 0; }
latexmk -pdf -g -f -silent -recorder- review-v2026.3.0.tex
